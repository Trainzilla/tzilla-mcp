{
  "name": "tzilla-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local MCP server for Trainzilla Coach (wraps the api.tzilla.live GraphQL API). MVP — read-only + calculators.",
  "bin": {
    "tzilla-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "http": "tsx src/http.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "try": "node scripts/try.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/express": "^4.17.21"
  }
}
