# Trainzilla GraphQL endpoint.
# Override explicitly when you want a custom backend URL.
# If omitted, tzilla-mcp will use:
#   TZ_ENVIRONMENT=staging    -> https://qa-be2.tzilla.live/graphql
#   otherwise                 -> https://api.tzilla.live/graphql
# Local backend example: http://127.0.0.1:4000/graphql
# TZ_ENVIRONMENT=staging
TZ_API_URL=https://api.tzilla.live/graphql

# A trainer's tokens (MVP auth). Grab these from the coach web app after login:
#   localStorage.getItem("token")        -> TZ_ACCESS_TOKEN
#   localStorage.getItem("refreshToken") -> TZ_REFRESH_TOKEN
# The server auto-refreshes the access token via refreshAccessToken when it expires.
TZ_ACCESS_TOKEN=
TZ_REFRESH_TOKEN=
